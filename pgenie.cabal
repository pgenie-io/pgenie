    containers,
    dhall,
    foldl,
    hspec,
    megaparsec,
    monad-parallel,
    pgenie:gen-bridge,
    pgenie:utils,
    postgresql-syntax,
    QuickCheck,
    syntactic-class,
    text,
    text-builder,
    vector,
    yaml-unscrambler,

