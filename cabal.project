constraints:
  autoexporter >=2.0.0.13 && <3,
  base >=4.11 && <5,
  bytestring >=0.10 && <0.13,
  data-has ^>=0.4,
  directory ^>=1.3,
  filepath ^>=1.5.4,
  hasql ^>=1.10.2.3,
  lawful-conversions ^>=0.3,
  megaparsec >=9 && <10,
  monad-parallel ^>=0.8,
  mtl >=2.3.1 && <3,
  optparse-applicative ^>=0.18.1,
  postgresql-syntax ^>=0.4.3,
  profunctors >=5.6 && <6,
  resourcet ^>=1.3,
  testcontainers ^>=0.5,
  text >=1.2 && <3,
  text-builder ^>=1.0.0.3,
  text-builder-lawful-conversions ^>=0.1,
  time >=1.12 && <2,
  tuple ^>=0.3.0.2,
  vector >=0.12 && <0.14,
  vector-extras ^>=0.3,
  vector-instances >=3.4.2 && <4,
  witherable ^>=0.5,
