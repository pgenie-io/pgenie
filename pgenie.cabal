cabal-version: 3.4
name: pgenie
version: 0
category:
synopsis:
description:
homepage: https://github.com/nikita-volkov/pgenie
bug-reports: https://github.com/nikita-volkov/pgenie/issues
author: Nikita Volkov <nikita.y.volkov@mail.ru>
maintainer: Nikita Volkov <nikita.y.volkov@mail.ru>
copyright: (c) 2025, Nikita Volkov
license: GPL-3.0-or-later
license-file: LICENSE

source-repository head
  type: git
  location: https://github.com/nikita-volkov/pgenie

common base
  default-language: Haskell2010
  default-extensions:
    BangPatterns
    BlockArguments
    ConstraintKinds
    DataKinds
    DefaultSignatures
    DeriveDataTypeable
    DeriveFoldable
    DeriveFunctor
    DeriveGeneric
    DeriveTraversable
    DerivingStrategies
    DuplicateRecordFields
    EmptyDataDecls
    FlexibleContexts
    FlexibleInstances
    FunctionalDependencies
    GADTs
    GeneralizedNewtypeDeriving
    ImportQualifiedPost
    LambdaCase
    LiberalTypeSynonyms
    MagicHash
    MultiParamTypeClasses
    MultiWayIf
    NoFieldSelectors
    NoImplicitPrelude
    NoMonomorphismRestriction
    NumericUnderscores
    OverloadedRecordDot
    OverloadedStrings
    ParallelListComp
    PatternGuards
    QuasiQuotes
    RankNTypes
    RecordWildCards
    ScopedTypeVariables
    StandaloneDeriving
    StrictData
    TemplateHaskell
    TupleSections
    TypeApplications
    TypeFamilies
    TypeOperators
    UnboxedTuples
    ViewPatterns

common executable
  import: base
  ghc-options:
    -O2
    -threaded
    "-with-rtsopts=-N -I0 -qg"

common test
  import: base
  ghc-options:
    -threaded
    "-with-rtsopts=-N -I0 -qg"

library base
  import: base
  hs-source-dirs: src/base/
  exposed-modules:
    Base.Prelude

  other-modules:
  build-depends:
    base >=4.11 && <5,
    bytestring >=0.10 && <0.13,
    lawful-conversions ^>=0.1.6.1,
    mtl >=2.3.1 && <3,
    profunctors >=5.6 && <6,
    text >=1.2 && <3,
    time >=1.12 && <2,
    tuple ^>=0.3.0.2,
    vector >=0.12 && <0.14,
    witherable ^>=0.5,

library modeller
  import: base
  hs-source-dirs: src/modeller/
  exposed-modules:
  other-modules:
    Modeller.Procedures.DescribeQuery
    Modeller.Statements.SelectRelationColumns
    Modeller.Statements.SelectType

  build-depends:
    attoparsec,
    hasql-dev,
    hasql-th,
    pgenie:base,
    pgenie:libpq-lawful-conversions,
    postgresql-libpq,
    vector >=0.12,

library libpq-lawful-conversions
  import: base
  hs-source-dirs: src/libpq-lawful-conversions/
  exposed-modules:
    LibpqLawfulConversions

  build-depends:
    base,
    lawful-conversions,
    postgresql-libpq,
