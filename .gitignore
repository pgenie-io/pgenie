# We apply the Gitignore Whitelist approach here.
# Everything but a specific list of files and directories listed here gets ignored.
# 
# More on the approach: https://jasonstitt.com/gitignore-whitelisting-patterns.

# Ignore everything in the root folder:
/*

# Unignore a specific list of files in the root folder:
!/.gitignore
!/LICENSE
!/README.md
!/CHANGELOG.md
!/AGENTS.md
!/CODING_STANDARDS.md
!/CONTEXT.md
!/*.cabal
!/cabal.project
!/cabal.project.freeze
!/.ormolu
!/stack.yaml
!/.haskell-coding-standards.lock

# Unignore subtrees:
!/.github/
!/design/
!/docs/
!/src/
!/.github/**
!/pgenie-utils/
!/pgenie-gen-contract-base/
!/pgenie-gen-contract-versioning/
!/pgenie-gen-contract-v4/
!/pgenie-gen-contract-v5/
!/pgenie-gen-bridge/
!/pgenie-logic/
!/pgenie-interpreters/
!/pgenie-infra/
!/pgenie-ui/

# Ignore noise:
.DS_Store
