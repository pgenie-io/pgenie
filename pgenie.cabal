cabal-version: 3.4
name: pgenie
version: 0
category: Database
synopsis: Type-safe PostgreSQL client code generator
description:
  Analyzes SQL migrations and queries to generate type-safe client libraries.

homepage: https://github.com/nikita-volkov/pgenie
bug-reports: https://github.com/nikita-volkov/pgenie/issues
author: Nikita Volkov <nikita.y.volkov@mail.ru>
maintainer: Nikita Volkov <nikita.y.volkov@mail.ru>
copyright: (c) 2025, Nikita Volkov
license: GPL-3.0-or-later
license-file: LICENSE
extra-source-files:
  cabal.project
  README.md

source-repository head
  type: git
  location: https://github.com/nikita-volkov/pgenie

common base
  default-language: GHC2024
  default-extensions:
    ApplicativeDo
    BlockArguments
    DefaultSignatures
    DeriveAnyClass
    DerivingVia
    DuplicateRecordFields
    FunctionalDependencies
    LiberalTypeSynonyms
    MagicHash
    MultiWayIf
    NoFieldSelectors
    NoImplicitPrelude
    NoMonomorphismRestriction
    OverloadedLabels
    OverloadedRecordDot
    OverloadedStrings
    ParallelListComp
    PatternSynonyms
    RecordWildCards
    StrictData
    TypeFamilies
    ViewPatterns

common executable
  import: base
  ghc-options:
    -O2
    -threaded
    "-with-rtsopts=-N -I0 -qg"

common test
  import: base
  ghc-options:
    -threaded
    "-with-rtsopts=-N -I0 -qg"

executable pgn
  import: executable
  hs-source-dirs: src/pgn/
  main-is: Main.hs
  autogen-modules: Paths_pgenie
  other-modules: Paths_pgenie
  build-depends:
    base,
    pgenie:infra,
    pgenie:ui,
    pgenie:utils,
    text,

library utils
  import: base
  hs-source-dirs: src/utils/
  exposed-modules:
    Utils.Prelude
    Utils.Text

  build-depends:
    algebraic-path,
    base,
    bytestring,
    containers,
    data-has,
    hashable,
    lawful-conversions,
    monad-parallel,
    mtl,
    profunctors,
    QuickCheck,
    quickcheck-instances,
    relations,
    syntactic-class,
    text,
    text-builder,
    text-builder-lawful-conversions,
    time,
    transformers,
    tuple,
    uuid,
    vector,
    vector-instances,
    witherable,

library gen-contract-base
  import: base
  hs-source-dirs: src/gen-contract-base/
  exposed-modules:
    GenContractBase.Aeson.Deriver
    GenContractBase.Dhall.Decode
    GenContractBase.Dhall.Deriving
    GenContractBase.Dhall.Orphans
    GenContractBase.Dhall.Orphans.NonEmpty
    GenContractBase.Dhall.Orphans.Path
    GenContractBase.Prelude
    GenContractBase.Prelude.Path

  build-depends:
    aeson,
    algebraic-path,
    base,
    cases,
    dhall,
    pgenie:utils,
    prettyprinter,
    template-haskell,
    text,

library gen-contract-versioning
  import: base
  hs-source-dirs: src/gen-contract-versioning/
  exposed-modules:
    GenContractVersioning

  build-depends:
    base,
    text,

library gen-contract-v4
  import: base
  hs-source-dirs: src/gen-contract-v4/
  exposed-modules:
    GenContractV4
    GenContractV4.Input
    GenContractV4.Output

  other-modules:
    GenContractV4.Input.ArraySettings
    GenContractV4.Input.CustomType
    GenContractV4.Input.CustomTypeDefinition
    GenContractV4.Input.EnumVariant
    GenContractV4.Input.Member
    GenContractV4.Input.Migration
    GenContractV4.Input.Name
    GenContractV4.Input.Primitive
    GenContractV4.Input.Project
    GenContractV4.Input.Query
    GenContractV4.Input.QueryFragment
    GenContractV4.Input.Result
    GenContractV4.Input.ResultRows
    GenContractV4.Input.ResultRowsCardinality
    GenContractV4.Input.Scalar
    GenContractV4.Input.Value
    GenContractV4.Input.Var
    GenContractV4.Input.Version
    GenContractV4.Output.File
    GenContractV4.Output.Output
    GenContractV4.Output.OutputOk
    GenContractV4.Output.Report

  build-depends:
    aeson,
    dhall,
    pgenie:gen-contract-base,
    pgenie:gen-contract-versioning,
    pgenie:utils,
    QuickCheck,

library gen-bridge
  import: base
  hs-source-dirs: src/gen-bridge/
  exposed-modules:
    GenBridge
    GenBridge.Contract

  other-modules:
    GenBridge.Bundle
    GenBridge.ContractVersion
    GenBridge.Dhall.ExprViews
    GenBridge.Dispatch
    GenBridge.Load
    GenBridge.Location

  build-depends:
    aeson,
    algebraic-path,
    dhall,
    dhall-json,
    microlens,
    pgenie:gen-contract-v5,
    pgenie:gen-contract-versioning,
    pgenie:utils,
    template-haskell,
